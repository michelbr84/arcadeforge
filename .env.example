# ===========================
# ArcadeForge — Environment
# ===========================
# Copy to .env and fill in your values.
# Required fields are marked with (REQUIRED).

# ---------------------------
# App (API)
# ---------------------------
APP_ENV=development                          # development | production | test
APP_BASE_URL=http://localhost:3000           # Frontend URL
API_BASE_URL=http://localhost:8000           # Backend API URL
APP_SECRET_KEY=change-me-please-long-random  # (REQUIRED) Session signing key — use a long random string

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------
# Database (PostgreSQL)
# ---------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arcadeforge  # (REQUIRED)
DATABASE_SSL=false                           # Set true for cloud Postgres (Neon, Supabase, etc.)

# Production compose vars (used by docker-compose.prod.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres                   # (REQUIRED in production) Change this!
POSTGRES_DB=arcadeforge

# ---------------------------
# Redis / Queue (arq)
# ---------------------------
REDIS_URL=redis://localhost:6379/0           # (REQUIRED)
REDIS_PASSWORD=                              # Set for production (used by docker-compose.prod.yml)

# ---------------------------
# Object Storage (artifacts, screenshots, builds)
# ---------------------------
STORAGE_DRIVER=local                         # local | s3
STORAGE_LOCAL_PATH=./data

# S3/MinIO (when STORAGE_DRIVER=s3)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=arcadeforge
S3_REGION=us-east-1

# ---------------------------
# Game Runtime Sandbox
# ---------------------------
SANDBOX_DRIVER=docker                        # "docker" (local dev only)
SANDBOX_IMAGE_NAME=arcadeforge-sandbox:latest
SANDBOX_SESSION_TTL_SECONDS=1800             # 30 minutes
SANDBOX_CPU_LIMIT=1                          # CPU cores per container
SANDBOX_MEM_LIMIT_MB=1024                    # Memory limit per container (MB)
SANDBOX_DISABLE_NETWORK=true                 # (REQUIRED true for production)
SANDBOX_WS_BASE_URL=ws://localhost           # WebSocket base for noVNC connections

# ---------------------------
# Cookies (API → browser)
# ---------------------------
COOKIE_DOMAIN=                               # empty for localhost, ".arcadeforge.io" for prod
COOKIE_SECURE=                               # empty = auto (secure in prod, not in dev); "true"/"false" to override

# ---------------------------
# Frontend (Next.js)
# ---------------------------
# API_URL is server-side only — used by Next.js rewrites and server components.
# Set this on Vercel/cloud to point to the production backend (e.g. Render URL).
API_URL=http://localhost:8000                # Server-side API URL (NOT exposed to browser)
# NEXT_PUBLIC_API_URL is no longer used — all API calls go through the Next.js proxy.

# ---------------------------
# Email (SMTP) — optional, needed for password reset emails in production
# ---------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@arcadeforge.local

# ---------------------------
# LLM (optional — AI-assisted generation)
# ---------------------------
LLM_MODE=off                                 # off | anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---------------------------
# Observability (optional)
# ---------------------------
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR
SENTRY_DSN=                                  # Sentry DSN for error tracking
SENTRY_DSN_API=                              # Separate Sentry DSN for API (optional)
