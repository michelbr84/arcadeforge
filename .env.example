# ===========================
# ArcadeForge — Environment
# ===========================

# ---------------------------
# App (API)
# ---------------------------
APP_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
APP_SECRET_KEY=change-me-please-long-random

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------
# Database (PostgreSQL)
# ---------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arcadeforge

# ---------------------------
# Redis / Queue (arq)
# ---------------------------
REDIS_URL=redis://localhost:6379/0
JOBS_QUEUE_NAME=arcadeforge_jobs

# ---------------------------
# Sessions / Auth
# ---------------------------
SESSION_COOKIE_NAME=af_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Password hashing
PASSWORD_HASH_ALGO=argon2id

# Email verification (set to true to require email verification)
EMAIL_VERIFICATION_ENABLED=false
EMAIL_TOKEN_TTL_MINUTES=60

# Password reset
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ---------------------------
# Email (SMTP) — optional for MVP
# ---------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@arcadeforge.local

# ---------------------------
# Object Storage (artifacts, screenshots, builds)
# ---------------------------
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./data

# S3/MinIO (when STORAGE_DRIVER=s3)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=arcadeforge
S3_REGION=us-east-1

# ---------------------------
# Game Runtime Sandbox
# ---------------------------
SANDBOX_RUNTIME_MODE=novnc
SANDBOX_IMAGE_NAME=arcadeforge-sandbox:latest
SANDBOX_SESSION_TTL_SECONDS=1800
SANDBOX_CPU_LIMIT=1
SANDBOX_MEM_LIMIT_MB=1024
SANDBOX_DISABLE_NETWORK=true
SANDBOX_WS_PUBLIC_BASE_URL=ws://localhost:8081

# ---------------------------
# LLM (optional — AI-assisted generation)
# ---------------------------
LLM_MODE=off
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---------------------------
# Observability (optional)
# ---------------------------
LOG_LEVEL=INFO
SENTRY_DSN=
