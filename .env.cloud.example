# ============================================
# ArcadeForge — Cloud Deployment Environment
# ============================================
# Copy to .env in each service. Values marked (REQUIRED) must be set.
#
# Services:
#   - Vercel: Next.js frontend
#   - Fly.io (api): FastAPI backend
#   - Fly.io (workers): arq generator, validator, sandbox workers
#   - Fly.io (sandbox): Sandbox runtime containers
#   - Neon: PostgreSQL database
#   - Upstash: Redis
#   - Cloudflare R2: Object storage


# ------------------------------------------
# Vercel — Next.js Frontend
# ------------------------------------------

API_URL=https://arcadeforge-api.fly.dev          # (REQUIRED) Fly.io API URL (server-side proxy)


# ------------------------------------------
# Fly.io — FastAPI API
# ------------------------------------------

APP_ENV=production                                    # (REQUIRED) Must be "production"
APP_BASE_URL=https://arcadeforge.vercel.app           # (REQUIRED) Frontend URL (Vercel)
API_BASE_URL=https://arcadeforge-api.fly.dev          # (REQUIRED) This API's own URL
APP_SECRET_KEY=                                       # (REQUIRED) Long random string for session signing

# CORS
CORS_ALLOWED_ORIGINS=https://arcadeforge.vercel.app   # (REQUIRED) Comma-separated allowed origins

# Database (Neon)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-1.aws.neon.tech/arcadeforge?sslmode=require  # (REQUIRED)
DATABASE_SSL=true                                     # (REQUIRED) Enable for Neon

# Redis (Upstash)
REDIS_URL=rediss://default:password@xxx.upstash.io:6379/0  # (REQUIRED) Note: rediss:// (TLS)

# Object Storage (Cloudflare R2)
STORAGE_DRIVER=s3                                     # (REQUIRED) Use "s3" in production
S3_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com  # (REQUIRED) R2 endpoint
S3_ACCESS_KEY_ID=                                     # (REQUIRED)
S3_SECRET_ACCESS_KEY=                                 # (REQUIRED)
S3_BUCKET=arcadeforge                                 # (REQUIRED)
S3_REGION=auto                                        # R2 uses "auto"

# Sandbox
SANDBOX_DRIVER=fly                                    # (REQUIRED) Use "fly" in production
SANDBOX_IMAGE_NAME=arcadeforge-sandbox:latest
SANDBOX_SESSION_TTL_SECONDS=1800
SANDBOX_CPU_LIMIT=1
SANDBOX_MEM_LIMIT_MB=512
SANDBOX_DISABLE_NETWORK=true                          # (REQUIRED) Must be true in production
SANDBOX_WS_BASE_URL=wss://arcadeforge-sandbox.fly.dev # (REQUIRED) WebSocket URL for noVNC

# Fly.io Machines (sandbox management)
FLY_API_TOKEN=                                        # (REQUIRED) From `flyctl tokens create`
FLY_SANDBOX_APP=arcadeforge-sandbox                   # Fly app name for sandbox machines
FLY_SANDBOX_REGION=iad                                # Fly region

# Cookies
COOKIE_DOMAIN=                                        # Set to ".arcadeforge.app" if using custom domain
COOKIE_SECURE=true                                    # (REQUIRED) Must be true for HTTPS

# LLM — Game generation
LLM_MODE=anthropic                                    # anthropic | openai
ANTHROPIC_API_KEY=                                    # Required if LLM_MODE=anthropic
OPENAI_API_KEY=                                       # Required if LLM_MODE=openai

# Email (SMTP)
SMTP_HOST=                                            # e.g. smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@arcadeforge.app

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=                                           # Frontend Sentry DSN (set in Vercel too)
SENTRY_DSN_API=                                       # API-specific Sentry DSN


# ------------------------------------------
# Fly.io — arq Workers
# ------------------------------------------
# Workers share the same env vars as the API above.
# Set them as secrets in the worker Fly app:
#   fly secrets set -a arcadeforge-workers DATABASE_URL="..." REDIS_URL="..." ...
#
# Worker processes are defined in workers/fly.toml [processes].


# ------------------------------------------
# Fly.io — Sandbox Runtime
# ------------------------------------------
# Sandbox containers are launched on-demand via the Machines API.
# The sandbox image is deployed to: registry.fly.io/arcadeforge-sandbox
# Deploy with: cd services/sandbox-runtime && fly deploy
