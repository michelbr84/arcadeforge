# ============================================
# ArcadeForge — Cloud Deployment Environment
# ============================================
# Services:
#   - Vercel: Next.js frontend
#   - Render: FastAPI API (free tier, no card required)
#   - Neon: PostgreSQL database (free tier)
#   - Upstash: Redis (pay-as-you-go)


# ------------------------------------------
# Vercel — Next.js Frontend
# ------------------------------------------

API_URL=https://arcadeforge-api.onrender.com      # (REQUIRED) Render API URL (server-side proxy)


# ------------------------------------------
# Render — FastAPI API
# ------------------------------------------

APP_ENV=production
APP_BASE_URL=https://arcadeforge-web.vercel.app
API_BASE_URL=https://arcadeforge-api.onrender.com
APP_SECRET_KEY=                                    # (REQUIRED) Long random string
CORS_ALLOWED_ORIGINS=https://arcadeforge-web.vercel.app
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_SSL=true
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379/0
STORAGE_DRIVER=local
COOKIE_SECURE=true
LOG_LEVEL=INFO

# LLM (optional — users configure their own keys in settings)
# No server-side LLM key needed.
